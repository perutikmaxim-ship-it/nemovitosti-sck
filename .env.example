# ============================================================
# Nemovitosti Bot - Konfigurace (.env)
# Zkopíruj tento soubor jako .env a vyplň hodnoty
# ============================================================

# --- POVINNÉ ---
TELEGRAM_TOKEN=sem_vloz_svuj_bot_token
TELEGRAM_CHAT_ID=sem_vloz_chat_id

# --- VOLITELNÉ (výchozí hodnoty jsou přednastaveny) ---

# Maximální cena v Kč (výchozí: 5000000)
# MAX_PRICE=5000000

# Interval kontroly v sekundách (výchozí: 900 = 15 minut)
# CHECK_INTERVAL=900

# Dispozice oddělené čárkou (výchozí: 2+kk,2+1)
# DISPOSITIONS=2+kk,2+1

# Lokality oddělené čárkou (výchozí: Kladno,Mělník,Kralupy nad Vltavou)
# LOCATIONS=Kladno,Mělník,Kralupy nad Vltavou

# Cesta k SQLite databázi (výchozí: data/listings.db)
# DB_PATH=data/listings.db

# Úroveň logování: DEBUG, INFO, WARNING, ERROR (výchozí: INFO)
# LOG_LEVEL=INFO

# Prodleva mezi requesty v sekundách (výchozí: 2.0)
# REQUEST_DELAY=2.0

# Timeout pro HTTP požadavky v sekundách (výchozí: 15)
# REQUEST_TIMEOUT=15
